# SEM4 Study Guides — environment variables
# Copy this file to .env.local for local dev, or set these in
# Vercel → Project Settings → Environment Variables for production.
#
# Set ANY ONE provider. Priority order if multiple are set:
#   OPENROUTER_API_KEY → ANTHROPIC_API_KEY → NVIDIA_API_KEY → OPENAI_API_KEY

# OpenRouter — multi-model gateway. Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic Claude — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# NVIDIA NIM — https://build.nvidia.com
# NVIDIA_API_KEY=nvapi-...

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Optional model overrides
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct
